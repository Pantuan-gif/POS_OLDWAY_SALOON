<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Reports"
             Title="Reports"
             BackgroundColor="#F3F3F3">

    <Grid RowDefinitions="Auto, *">

        <!-- Header with Hamburger Menu -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *"
              Padding="10">
            <ImageButton Source="menu_icon.png"
                         Command="{Binding MenuCommand}"
                         Grid.Column="0"
                         WidthRequest="30"
                         HeightRequest="30"/>
            <Label Text="Reports"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   Grid.Column="1"/>
        </Grid>

        <!-- Reports Options -->
        <StackLayout Grid.Row="1"
                     Padding="20"
                     Spacing="15">

            <!-- Transaction History -->
            <Frame BorderColor="LightGray"
                   CornerRadius="8"
                   Padding="15">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Image Source="transaction_icon.png"
                           WidthRequest="40"
                           HeightRequest="40"
                           Grid.Column="0"/>
                    <StackLayout Grid.Column="1"
                                 Padding="10,0">
                        <Label Text="Transaction History"
                               FontAttributes="Bold"/>
                        <Label Text="List of all transactions"
                               FontSize="12"
                               TextColor="Gray"/>
                    </StackLayout>
                    <ImageButton Source="arrow_icon.png"
                                 Grid.Column="2"
                                 Command="{Binding NavigateTransactionHistoryCommand}"/>
                </Grid>
            </Frame>

            <!-- Inventory Report -->
            <Frame BorderColor="LightGray"
                   CornerRadius="8"
                   Padding="15">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Image Source="inventory_icon.png"
                           WidthRequest="40"
                           HeightRequest="40"
                           Grid.Column="0"/>
                    <StackLayout Grid.Column="1"
                                 Padding="10,0">
                        <Label Text="Inventory Report"
                               FontAttributes="Bold"/>
                        <Label Text="Check total products in stock"
                               FontSize="12"
                               TextColor="Gray"/>
                    </StackLayout>
                    <ImageButton Source="arrow_icon.png"
                                 Grid.Column="2"
                                 Command="{Binding NavigateInventoryReportCommand}"/>
                </Grid>
            </Frame>

            <!-- Out of Stock Items -->
            <Frame BorderColor="LightGray"
                   CornerRadius="8"
                   Padding="15">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Image Source="outofstock_icon.png"
                           WidthRequest="40"
                           HeightRequest="40"
                           Grid.Column="0"/>
                    <StackLayout Grid.Column="1"
                                 Padding="10,0">
                        <Label Text="Out of Stock Items"
                               FontAttributes="Bold"/>
                        <Label Text="View out of stock products"
                               FontSize="12"
                               TextColor="Gray"/>
                    </StackLayout>
                    <ImageButton Source="arrow_icon.png"
                                 Grid.Column="2"
                                 Command="{Binding NavigateOutOfStockCommand}"/>
                </Grid>
            </Frame>

        </StackLayout>
    </Grid>
</ContentPage>