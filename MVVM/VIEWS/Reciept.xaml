<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Reciept"
             Title="Reciept"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Button Text="←" Command="{Binding BackCommand}" BackgroundColor="Transparent" TextColor="#5C2E0C" />
                <Label Text="E-Receipt" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" Grid.Column="1" />
                <BoxView WidthRequest="24" Grid.Column="2" />
            </Grid>

            <!-- Receipt Card (responsive) -->
            <Frame CornerRadius="14" BackgroundColor="#5C2E0C" Padding="16" HasShadow="True" HorizontalOptions="FillAndExpand">
                <VerticalStackLayout Spacing="10">

                    <!-- Icon + Store -->
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Frame BackgroundColor="#1A8F4B" CornerRadius="28" WidthRequest="56" HeightRequest="56" Padding="0">
                            <Label Text="✔" FontSize="28" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Frame>
                        <Label Text="OLDWAY SALOON" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Liquor Store" FontSize="12" TextColor="#DDDDDD" />
                        <Label Text="46551 140th Street East, Lancaster, California" FontSize="12" TextColor="#DDDDDD" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Items -->
                    <CollectionView ItemsSource="{Binding Items}" SelectionMode="None" BackgroundColor="Transparent">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <!-- Use two-row layout so long texts don't overlap -->
                                <Grid Padding="6" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="8">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding ProductName}" TextColor="White" LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Quantity, StringFormat='x{0}'}" TextColor="#DDDDDD" HorizontalOptions="End" />
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding TotalPrice, StringFormat='₱{0:F2}'}" TextColor="#DDDDDD" HorizontalOptions="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                        <CollectionView.EmptyView>
                            <Label Text="(No items)" TextColor="#DDDDDD" HorizontalOptions="Center" />
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Details -->
                    <VerticalStackLayout Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Reference" TextColor="#DDDDDD" />
                            <Label Text="{Binding ReferenceNumber}" TextColor="#FFFFFF" LineBreakMode="WordWrap" MaxLines="3" HorizontalOptions="EndAndExpand" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Date" TextColor="#DDDDDD" />
                            <Label Text="{Binding Date}" TextColor="#FFFFFF" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Time" TextColor="#DDDDDD" />
                            <Label Text="{Binding Time}" TextColor="#FFFFFF" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Operator" TextColor="#DDDDDD" />
                            <Label Text="{Binding OperatorName}" TextColor="#FFFFFF" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Payment" TextColor="#DDDDDD" />
                            <Label Text="{Binding PaymentMethod}" TextColor="#FFFFFF" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Tendered" TextColor="#DDDDDD" />
                            <Label Text="{Binding TenderedAmount, StringFormat='₱{0:F2}'}" TextColor="#FFFFFF" HorizontalOptions="End" />
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Change" TextColor="#DDDDDD" />
                            <Label Text="{Binding Change, StringFormat='₱{0:F2}'}" TextColor="#FFFFFF" HorizontalOptions="End" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" BackgroundColor="#AA9A8A" />

                    <!-- Total -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Payment" FontAttributes="Bold" TextColor="White" />
                        <Label Text="{Binding TotalPayment}" Grid.Column="1" FontAttributes="Bold" TextColor="#8CFFB4" />
                    </Grid>

                    <Label Text="Note: Please show this receipt and pay to the cashier" FontSize="11" TextColor="#DDDDDD" />
                    <Label Text="Thank you!" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White" />
                </VerticalStackLayout>
            </Frame>

            <!-- Back Button -->
            <Button Text="← Back To Orders" Clicked="OnBackClicked" BackgroundColor="Transparent" TextColor="#5C2E0C" FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>