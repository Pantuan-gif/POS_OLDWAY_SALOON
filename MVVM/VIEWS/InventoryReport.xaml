<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.InventoryReport"
             Title="Inventory Report"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, Auto, Auto, *">

        <!-- Header with Back Button -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *"
              Padding="10"
              BackgroundColor="White">
            <ImageButton Source="back_icon.png"
                         Command="{Binding BackCommand}"
                         Grid.Column="0"
                         WidthRequest="30"
                         HeightRequest="30"
                         VerticalOptions="Center"/>
            <Label Text="Inventory Report"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   Margin="10,0,0,0"
                   Grid.Column="1"/>
        </Grid>

        <!-- Summary KPI strip -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*, *, *"
              BackgroundColor="White"
              Padding="10,8"
              Margin="0,0,0,4">

            <StackLayout Grid.Column="0" HorizontalOptions="Center">
                <Label Text="{Binding TotalProducts}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Products"
                       FontSize="11"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <BoxView Grid.Column="0"
                     WidthRequest="1"
                     BackgroundColor="LightGray"
                     HorizontalOptions="End"
                     VerticalOptions="Fill"/>

            <StackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="{Binding TotalStock}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#2E7D32"/>
                <Label Text="Total Stock"
                       FontSize="11"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <BoxView Grid.Column="1"
                     WidthRequest="1"
                     BackgroundColor="LightGray"
                     HorizontalOptions="End"
                     VerticalOptions="Fill"/>

            <StackLayout Grid.Column="2" HorizontalOptions="Center">
                <Label Text="{Binding TotalSoldToday}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#C62828"/>
                <Label Text="Sold Today"
                       FontSize="11"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </StackLayout>
        </Grid>

        <!-- Search Bar -->
        <SearchBar Placeholder="Search product or category…"
                   Grid.Row="2"
                   Margin="10,6"
                   HorizontalOptions="FillAndExpand"
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}"/>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#8B0000"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>

        <!-- Error message -->
        <Label Grid.Row="3"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               IsVisible="{Binding ErrorMessage, Converter={x:StaticResource StringNotEmptyConverter}}"
               Margin="16"/>

        <!-- Product List -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Products}"
                        IsVisible="{Binding IsBusy, Converter={x:StaticResource InvertedBoolConverter}}">

            <!-- Empty state -->
            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                    <Label Text="No products found."
                           TextColor="Gray"
                           HorizontalOptions="Center"/>
                    <Button Text="Refresh"
                            Command="{Binding LoadCommand}"
                            BackgroundColor="#8B0000"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="20,8"/>
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray"
                           Margin="8,4"
                           Padding="10"
                           CornerRadius="10"
                           HasShadow="False">
                        <Grid ColumnDefinitions="Auto, *"
                              RowDefinitions="Auto, Auto, Auto, Auto"
                              ColumnSpacing="12">

                            <!-- Product Image -->
                            <Image Source="{Binding Image}"
                                   WidthRequest="64"
                                   HeightRequest="64"
                                   Aspect="AspectFill"
                                   Grid.RowSpan="4"
                                   Grid.Column="0"
                                   VerticalOptions="Center"/>

                            <!-- Product Name -->
                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   Grid.Row="0"
                                   Grid.Column="1"/>

                            <!-- Type | Volume -->
                            <StackLayout Orientation="Horizontal"
                                         Spacing="8"
                                         Grid.Row="1"
                                         Grid.Column="1">
                                <Label Text="{Binding Type}"
                                       FontSize="12"
                                       TextColor="Gray"/>
                                <Label Text="·" TextColor="Gray" FontSize="12"
                                       IsVisible="{Binding Volume, Converter={x:StaticResource StringNotEmptyConverter}}"/>
                                <Label Text="{Binding Volume}"
                                       FontSize="12"
                                       TextColor="Gray"
                                       IsVisible="{Binding Volume, Converter={x:StaticResource StringNotEmptyConverter}}"/>
                            </StackLayout>

                            <!-- Price -->
                            <Label Text="{Binding PriceDisplay}"
                                   TextColor="#2E7D32"
                                   FontAttributes="Bold"
                                   Grid.Row="2"
                                   Grid.Column="1"/>

                            <!-- Sold today | Stocks left -->
                            <StackLayout Orientation="Horizontal"
                                         Spacing="16"
                                         Grid.Row="3"
                                         Grid.Column="1">
                                <Label Text="{Binding SoldTodayDisplay}"
                                       FontSize="12"
                                       TextColor="#C62828"/>
                                <Label Text="{Binding StocksDisplay}"
                                       FontSize="12"
                                       TextColor="#555"/>
                            </StackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
