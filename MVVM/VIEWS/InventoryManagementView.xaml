<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             xmlns:models="clr-namespace:POS_OLDWAY_SALOON.MVVM.MODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.InventoryManagementView"
             x:DataType="vm:InventoryManagementViewModel"
             BackgroundColor="#FFFFFF"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:InventoryManagementViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="BrandDark">#1A1005</Color>
            <Color x:Key="BrandGold">#8B5E1A</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="TextWhite">#FFFFFF</Color>
            <Color x:Key="TextGray">#888888</Color>
            <Color x:Key="DividerColor">#E0E0E0</Color>

            <!-- Category Card DataTemplate -->
            <DataTemplate x:Key="CategoryCardTemplate" x:DataType="models:Category">
                <Frame Margin="4"
                       Padding="0"
                       CornerRadius="12"
                       HasShadow="True"
                       BorderColor="#DDDDDD"
                       BackgroundColor="#FFFFFF"
                       IsClippedToBounds="True">
                    <VerticalStackLayout Spacing="0">

                        <!-- Category Name + Stock -->
                        <Grid Padding="10,8,10,4"
                              ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="{Binding CategoryName}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#1A1005"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding StockDisplay}"
                                   FontSize="11"
                                   TextColor="#888888"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Product Image -->
                        <Image Source="{Binding PhotoPath}"
                               Aspect="AspectFit"
                               HeightRequest="90"
                               Margin="8,4" />

                        <!-- Manage Button -->
                        <Button Text="Manage"
                                BackgroundColor="#4A2C0A"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                FontSize="13"
                                CornerRadius="0"
                                HeightRequest="38"
                                Margin="0"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryManagementViewModel}}, Path=ManageCategoryCommand}"
                                CommandParameter="{Binding .}" />
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Spacing="0">

        <!-- ── HEADER ── -->
        <Grid Padding="16,14"
              BackgroundColor="#FFFFFF"
              ColumnDefinitions="Auto,*">
            <Label Grid.Column="0"
                   Text="≡"
                   FontSize="24"
                   TextColor="#1A1005"
                   VerticalOptions="Center"
                   Margin="0,0,10,0" />
            <Label Grid.Column="1"
                   Text="Inventory Management"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#1A1005"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Divider -->
        <BoxView HeightRequest="1" Color="#E0E0E0" />

        <!-- ── SEARCH + ADD CATEGORY ── -->
        <Grid Padding="12,10"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              BackgroundColor="#FFFFFF">

            <Frame Grid.Column="0"
                   Padding="10,0"
                   CornerRadius="8"
                   BorderColor="#CCCCCC"
                   HasShadow="False"
                   HeightRequest="42"
                   BackgroundColor="#FFFFFF">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                    <Label Grid.Column="0"
                           Text="🔍"
                           FontSize="14"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           Text="{Binding SearchText}"
                           Placeholder="Search"
                           PlaceholderColor="#AAAAAA"
                           FontSize="14"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <Button Grid.Column="1"
                    Text="+ Add Category"
                    BackgroundColor="#4A2C0A"
                    TextColor="#FFFFFF"
                    FontSize="13"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="12,0"
                    HeightRequest="42"
                    Command="{Binding AddCategoryCommand}" />
        </Grid>

        <!-- ── CATEGORY GRID ── -->
        <ScrollView>
            <CollectionView ItemsSource="{Binding FilteredCategories}"
                            Margin="8,4,8,16">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="4"
                                     VerticalItemSpacing="4" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Category">
                        <Frame Margin="4"
                               Padding="0"
                               CornerRadius="12"
                               HasShadow="True"
                               BorderColor="#DDDDDD"
                               BackgroundColor="#FFFFFF"
                               IsClippedToBounds="True">
                            <VerticalStackLayout Spacing="0">

                                <Grid Padding="10,8,10,4"
                                      ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding CategoryName}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#1A1005"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding StockDisplay}"
                                           FontSize="11"
                                           TextColor="#888888"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Image Source="{Binding PhotoPath}"
                                       Aspect="AspectFit"
                                       HeightRequest="90"
                                       Margin="8,4" />

                                <Button Text="Manage"
                                        BackgroundColor="#4A2C0A"
                                        TextColor="#FFFFFF"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        CornerRadius="0"
                                        HeightRequest="38"
                                        Margin="0" 
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryManagementViewModel}}, Path=ManageCategoryCommand}"
                                        CommandParameter="{Binding .}"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

    </VerticalStackLayout>
</ContentPage>
