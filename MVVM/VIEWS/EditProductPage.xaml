<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.EditProductPage"
             x:DataType="vm:EditProductPageViewModel"
             BackgroundColor="#FFFFFF"
             Title="Edit Product"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="FieldLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="#1A1005" />
                <Setter Property="Margin" Value="0,12,0,4" />
            </Style>

            <Style x:Key="EntryFrameStyle" TargetType="Frame">
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="BorderColor" Value="#CCCCCC" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BackgroundColor" Value="#FFFFFF" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>

            <Style x:Key="FieldEntryStyle" TargetType="Entry">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="#1A1005" />
                <Setter Property="HeightRequest" Value="44" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Spacing="0">

        <!-- ── HEADER ── -->
        <Grid Padding="12,14" BackgroundColor="#FFFFFF" ColumnDefinitions="Auto,*">

            <!-- Back Button -->
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="16"
                    BackgroundColor="#4A2C0A"
                    TextColor="White"
                    WidthRequest="36"
                    HeightRequest="36"
                    CornerRadius="8"
                    Command="{Binding GoBackCommand}" />

            <Label Grid.Column="1"
                   Text="Edit Product"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#1A1005"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Accent divider -->
        <BoxView HeightRequest="1.5" Color="#4A2C0A" />

        <!-- ── BUSY INDICATOR ── -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#4A2C0A"
                           HeightRequest="40"
                           HorizontalOptions="Center" />

        <!-- ── ERROR BANNER ── -->
        <Label Text="{Binding ErrorMessage}"
               TextColor="#CC0000"
               FontSize="13"
               Margin="20,4,20,0"
               HorizontalOptions="Center" />

        <!-- ── FORM ── -->
        <ScrollView>
            <VerticalStackLayout Padding="20,8,20,20" Spacing="0">

                <!-- Product Name -->
                <Label Text="Product Name" Style="{StaticResource FieldLabelStyle}" />
                <Frame Style="{StaticResource EntryFrameStyle}">
                    <Entry Text="{Binding ProductName}"
                           Placeholder="Enter product name"
                           PlaceholderColor="#AAAAAA"
                           Style="{StaticResource FieldEntryStyle}" />
                </Frame>

                <!-- Category (read-only) -->
                <Label Text="Category" Style="{StaticResource FieldLabelStyle}" />
                <Frame Style="{StaticResource EntryFrameStyle}">
                    <Entry Text="{Binding CategoryName}"
                           Style="{StaticResource FieldEntryStyle}"
                           IsEnabled="False"
                           TextColor="#888888" />
                </Frame>

                <!-- Size (ml) -->
                <Label Text="Size (ml)" Style="{StaticResource FieldLabelStyle}" />
                <Frame Style="{StaticResource EntryFrameStyle}">
                    <Entry Text="{Binding SizeMl}"
                           Keyboard="Numeric"
                           Placeholder="0"
                           PlaceholderColor="#AAAAAA"
                           Style="{StaticResource FieldEntryStyle}" />
                </Frame>

                <!-- Price -->
                <Label Text="Price (₱)" Style="{StaticResource FieldLabelStyle}" />
                <Frame Style="{StaticResource EntryFrameStyle}">
                    <Entry Text="{Binding Price}"
                           Keyboard="Numeric"
                           Placeholder="0.00"
                           PlaceholderColor="#AAAAAA"
                           Style="{StaticResource FieldEntryStyle}" />
                </Frame>

                <!-- Quantity with stepper -->
                <Label Text="Quantity" Style="{StaticResource FieldLabelStyle}" />
                <Grid ColumnDefinitions="*,44,44" RowDefinitions="44">
                    <Entry Grid.Column="0"
                           Text="{Binding Quantity}"
                           Keyboard="Numeric"
                           Margin="0,0,0,0"
                           BackgroundColor="Transparent"
                           TextColor="#1A1005"
                           FontSize="14"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="+"
                            BackgroundColor="#1A1005"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            Command="{Binding IncrementQuantityCommand}" />
                    <Button Grid.Column="2"
                            Text="−"
                            BackgroundColor="#1A1005"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            Command="{Binding DecrementQuantityCommand}" />
                </Grid>

                <!-- Photo picker -->
                <Label Text="Photo" Style="{StaticResource FieldLabelStyle}" />
                <Grid ColumnDefinitions="Auto,*" HeightRequest="44">
                    <Button Grid.Column="0"
                            Text="Choose File"
                            BackgroundColor="#DDDDDD"
                            TextColor="#1A1005"
                            FontSize="13"
                            Command="{Binding PickPhotoAsyncCommand}" />
                    <Label Grid.Column="1"
                           Text="{Binding PhotoFileName}"
                           FontSize="13"
                           TextColor="#888888"
                           VerticalOptions="Center"
                           Margin="10,0" />
                </Grid>

                <!-- Photo preview -->
                <Image Source="{Binding PhotoPath}"
                       HeightRequest="120"
                       Aspect="AspectFit"
                       Margin="0,12,0,0" />

                <!-- Save Button -->
                <Button Text="Save Changes"
                        BackgroundColor="#4A2C0A"
                        TextColor="White"
                        IsEnabled="True"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="50"
                        Margin="0,24,0,0"
                        Command="{Binding SaveCommand}" />

            </VerticalStackLayout>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>