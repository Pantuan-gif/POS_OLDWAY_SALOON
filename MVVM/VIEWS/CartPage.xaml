<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             xmlns:models="clr-namespace:POS_OLDWAY_SALOON.MVVM.MODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.CartPage"
             x:DataType="vm:CartViewModel"
             Title="Cart">

    <ContentPage.BindingContext>
        <vm:CartViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="12">
        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CartItem">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding ProductName}" />
                        <Label Text="{Binding TotalPrice, StringFormat='{0:C2}'}" Grid.Column="1" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid ColumnDefinitions="*,Auto">
            <Label Text="Total" />
            <Label Text="{Binding TotalPrice, StringFormat='{0:C2}'}" Grid.Column="1" />
        </Grid>

        <Button Text="Proceed to Payment" Command="{Binding ProceedCommand}" />
    </VerticalStackLayout>
</ContentPage>
