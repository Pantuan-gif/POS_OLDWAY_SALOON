<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             xmlns:models="clr-namespace:POS_OLDWAY_SALOON.MVVM.MODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.OrderingManagement"
             x:DataType="vm:OrderingManagementViewModel"
             Title="Ordering"
             BackgroundColor="#F5F5F5">

    <ContentPage.BindingContext>
        <vm:OrderingManagementViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Label Text="OLDWAY SALOON"
               FontSize="24"
               HorizontalOptions="Center"
               Margin="0,10"
               Grid.Row="0" />

        <!-- Search and Categories (placeholders) -->
        <Grid Grid.Row="1" Padding="8" ColumnDefinitions="*,150">
            <SearchBar Placeholder="Search"
                       HorizontalOptions="FillAndExpand"
                       Text="{Binding SearchText, Mode=TwoWay}" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding Categories}"
                    ItemDisplayBinding="{Binding CategoryName}"
                    SelectedItem="{Binding SelectedCategory}"
                    WidthRequest="150" />
        </Grid>

        <!-- Product List (single-column mobile-friendly cards) -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Products}"
                        SelectionMode="None"
                        Margin="8,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <Label Text="No products" HorizontalOptions="Center" VerticalOptions="Center" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ProductSelection">
                    <Frame BorderColor="#E6D7C9" BackgroundColor="White" Margin="0" Padding="12" CornerRadius="10" HasShadow="True">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="12">
                                <Image Source="{Binding Product.PhotoPath}" HeightRequest="92" WidthRequest="92" Aspect="AspectFill" />
                                <VerticalStackLayout VerticalOptions="Center" Spacing="4" HorizontalOptions="FillAndExpand">
                                    <Label Text="{Binding Product.ProductName}" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Product.SizeDisplay}" FontSize="12" TextColor="#666" />
                                    <Label Text="{Binding Product.PriceDisplay}" FontAttributes="Bold" TextColor="#1A8F4B" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10" HorizontalOptions="FillAndExpand">
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Button Text="-" WidthRequest="36" HeightRequest="36"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DecrementQuantityCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Label Text="{Binding SelectedQuantity}" VerticalOptions="Center" />
                                    <Button Text="+" WidthRequest="36" HeightRequest="36"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IncrementQuantityCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>

                                <Button Text="Add to cart" BackgroundColor="#5C2E0C" TextColor="White" CornerRadius="8" HorizontalOptions="EndAndExpand"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AddSelectedToCartCommand}"
                                        CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom Summary Bar -->
        <Grid Grid.Row="3" Padding="8">
            <Frame BackgroundColor="#5C2E0C" CornerRadius="10" Padding="12">
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="End">
                    <VerticalStackLayout>
                        <Label Text="{Binding CartSummaryTotalItems}" TextColor="White" />
                        <Label Text="{Binding CartSummaryTotalPrice}" TextColor="#8CFFB4" FontAttributes="Bold" />
                    </VerticalStackLayout>

                    <Button Text="PROCEED" BackgroundColor="White" TextColor="#5C2E0C" WidthRequest="120" HeightRequest="44" Command="{Binding ProceedCommand}" HorizontalOptions="End" />
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
