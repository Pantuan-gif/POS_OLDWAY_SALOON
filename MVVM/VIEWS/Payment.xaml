<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Payment"
             Title="Payment"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto">
            <Button Text="←"
                    Command="{Binding BackCommand}"
                    BackgroundColor="#5C2E0C"
                    TextColor="White"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="8"/>

            <Label Text="Checkout"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Grid.Column="1"/>

            <BoxView Grid.Column="2" WidthRequest="40"/>
        </Grid>

        <!-- Store Name -->
        <Label Text="OLDWAY SALOON"
               HorizontalOptions="Center"
               FontAttributes="Bold"
               FontSize="16"
               LetterSpacing="2"/>

        <!-- Items Section -->
        <Label Text="Items"
               FontAttributes="Bold"
               FontSize="16"/>

        <VerticalStackLayout Spacing="8">

            <!-- Item Row -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="2x Jack Daniel's"/>
                <Label Text="$31.96" Grid.Column="1"/>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <Label Text="1x Chivas Regal"/>
                <Label Text="$17.88" Grid.Column="1"/>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <Label Text="3x Jack Daniel's"/>
                <Label Text="$39.00" Grid.Column="1"/>
            </Grid>

        </VerticalStackLayout>

        <!-- Divider -->
        <BoxView HeightRequest="1" BackgroundColor="Black"/>

        <!-- Total -->
        <Grid ColumnDefinitions="*,Auto">
            <Label Text="Total"
                   FontAttributes="Bold"
                   FontSize="16"/>
            <Label Text="{Binding TotalAmount}"
                   Grid.Column="1"
                   FontAttributes="Bold"
                   FontSize="16"
                   TextColor="Green"/>
        </Grid>

        <!-- Divider -->
        <BoxView HeightRequest="1" BackgroundColor="Black"/>

        <!-- Payment Method -->
        <Label Text="Payment Method"
               FontAttributes="Bold"
               FontSize="16"/>

        <VerticalStackLayout Spacing="10">

            <!-- Cash -->
            <Frame BorderColor="#CCCCCC" CornerRadius="10" Padding="10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <RadioButton IsChecked="True"
                                 GroupName="Payment"
                                 Command="{Binding SelectPaymentCommand}"
                                 CommandParameter="Cash"/>

                    <Label Text="Cash"
                           VerticalOptions="Center"
                           Grid.Column="1"/>

                    <Label Text="💵 Cash"
                           TextColor="Green"
                           Grid.Column="2"/>
                </Grid>
            </Frame>

            <!-- GCash -->
            <Frame BorderColor="#CCCCCC" CornerRadius="10" Padding="10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <RadioButton GroupName="Payment"
                                 Command="{Binding SelectPaymentCommand}"
                                 CommandParameter="GCash"/>

                    <Label Text="GCash"
                           VerticalOptions="Center"
                           Grid.Column="1"/>

                    <Label Text="🔵 GCash"
                           TextColor="Blue"
                           Grid.Column="2"/>
                </Grid>
            </Frame>

            <!-- PayMaya -->
            <Frame BorderColor="#CCCCCC" CornerRadius="10" Padding="10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <RadioButton GroupName="Payment"
                                 Command="{Binding SelectPaymentCommand}"
                                 CommandParameter="PayMaya"/>

                    <Label Text="PayMaya"
                           VerticalOptions="Center"
                           Grid.Column="1"/>

                    <Label Text="🟢 PayMaya"
                           TextColor="Green"
                           Grid.Column="2"/>
                </Grid>
            </Frame>

        </VerticalStackLayout>

        <!-- Pay Button -->
        <Button Text="Pay Now"
                Command="{Binding PayCommand}"
                BackgroundColor="#5C2E0C"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="8"
                HeightRequest="50"
                Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>