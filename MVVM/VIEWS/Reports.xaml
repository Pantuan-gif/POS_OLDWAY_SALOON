<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Reports"
             Title="Reports"
             BackgroundColor="#F3F3F3">

    <ContentPage.BindingContext>
        <vm:ReportsViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, *">

        <!-- Report Options -->
        <ScrollView Grid.Row="1">
            <StackLayout Padding="20" Spacing="15">

                <!-- Transaction History -->
                <Frame BorderColor="LightGray"
                       CornerRadius="10"
                       Padding="15"
                       HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateTransactionHistoryCommand}"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                        <Frame Grid.Column="0"
                               BackgroundColor="#E8F4FD"
                               CornerRadius="8"
                               Padding="8"
                               HasShadow="False">
                            <Image Source="order.svg"
                                   WidthRequest="28"
                                   HeightRequest="28"/>
                        </Frame>
                        <StackLayout Grid.Column="1" Padding="12,0" VerticalOptions="Center">
                            <Label Text="Transaction History"
                                   FontAttributes="Bold"
                                   FontSize="15"/>
                            <Label Text="View all completed orders"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </StackLayout>
                        <Label Text="›"
                               Grid.Column="2"
                               FontSize="24"
                               TextColor="Gray"
                               VerticalOptions="Center"/>
                    </Grid>
                </Frame>

                <!-- Inventory Report -->
                <Frame BorderColor="LightGray"
                       CornerRadius="10"
                       Padding="15"
                       HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateInventoryReportCommand}"/>
                    </Frame.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                        <Frame Grid.Column="0"
                               BackgroundColor="#E8F8F0"
                               CornerRadius="8"
                               Padding="8"
                               HasShadow="False">
                            <Image Source="inventory.png"
                                   WidthRequest="28"
                                   HeightRequest="28"/>
                        </Frame>
                        <StackLayout Grid.Column="1" Padding="12,0" VerticalOptions="Center">
                            <Label Text="Inventory Report"
                                   FontAttributes="Bold"
                                   FontSize="15"/>
                            <Label Text="Stock levels and daily sales per product"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </StackLayout>
                        <Label Text="›"
                               Grid.Column="2"
                               FontSize="24"
                               TextColor="Gray"
                               VerticalOptions="Center"/>
                    </Grid>
                </Frame>


            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
