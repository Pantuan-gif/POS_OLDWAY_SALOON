<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Dashboard"
             Title="Dashboard">
    
    
    <FlyoutPage.Flyout>
        <views:FlyoutMenu x:Name="flyoutPage"/>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <views:Home/>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>
</FlyoutPage>