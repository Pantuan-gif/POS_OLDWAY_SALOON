<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:POS_OLDWAY_SALOON"
             xmlns:converters="clr-namespace:POS_OLDWAY_SALOON.Converters"
             x:Class="POS_OLDWAY_SALOON.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="/Resources/Styles/OldWaySaloon.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:StringNotEmptyToBoolConverter x:Key="StringNotEmptyToBool" />
        </ResourceDictionary>
    </Application.Resources>

</Application>
