<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Registration"
             Title="Registration">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="Create A Account"
               FontSize="50"
               FontAttributes="Bold"
               HorizontalTextAlignment="Start"
               HorizontalOptions="Center"/>

        <!-- First Name -->
        <Border Stroke="Transparent" Padding="5">
            <VerticalStackLayout>
                <Label Text="First Name"
                       FontAttributes="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>
                <Border Style="{StaticResource EntryBorder}">
                    <Entry Visual="Default"
                           BackgroundColor="Transparent"
                           Text="{Binding FirstName}" />
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Last Name -->
        <Border Stroke="Transparent" Padding="5">
            <VerticalStackLayout>
                <Label Text="Last Name"
                       FontAttributes="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>
                <Border Style="{StaticResource EntryBorder}">
                    <Entry Visual="Default"
                           BackgroundColor="Transparent"
                           Text="{Binding LastName}" />
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Email -->
        <Border Stroke="Transparent" Padding="5">
            <VerticalStackLayout>
                <Label Text="Email"
                       FontAttributes="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>
                <Border Style="{StaticResource EntryBorder}">
                    <Entry Keyboard="Email"
                           Visual="Default"
                           BackgroundColor="Transparent"
                           Text="{Binding Email}" />
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Password -->
        <Border Stroke="Transparent" Padding="5">
            <VerticalStackLayout>
                <Label Text="Password"
                       FontAttributes="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>
                <Border Style="{StaticResource EntryBorder}">
                    <Grid ColumnDefinitions="*,0.2*">
                        <Entry Grid.Column="0"
                               Text="{Binding Password}"
                               IsPassword="{Binding IsPasswordHidden}" />
                        <ImageButton Grid.Column="1"
                                     Source="eye.svg"
                                     Command="{Binding TogglePasswordCommand}" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Confirm Password -->
        <Border Stroke="Transparent" Padding="5">
            <VerticalStackLayout>
                <Label Text="Confirm Password"
                       FontAttributes="Bold"
                       FontSize="16"
                       Margin="0,0,0,10"/>
                <Border Style="{StaticResource EntryBorder}">
                    <Grid ColumnDefinitions="*,0.2*">
                        <Entry Grid.Column="0"
                               Text="{Binding ConfirmPassword}"
                               IsPassword="{Binding IsConfirmPasswordHidden}" />
                        <ImageButton Grid.Column="1"
                                     Source="eye.svg"
                                     Command="{Binding ToggleConfirmPasswordCommand}" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <!-- Role is set programmatically; picker removed -->

        <!-- Sign Up Button -->
        <Button Text="Register"
                Margin="5,0,5,0"
                Clicked="Button_Clicked" />
        <Button Text="Cancel"
                BorderColor="Black"
                BorderWidth="1"
                BackgroundColor="White"
                TextColor="Black"
                Margin="5,0,5,0"
                Clicked="Button_Clicked" />
    </VerticalStackLayout>
</ContentPage>
