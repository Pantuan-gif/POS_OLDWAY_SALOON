<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.TransactionReports"
             Title="Transaction History"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *">

        <!-- Header with Back Button -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto, *, Auto"
              Padding="10"
              BackgroundColor="White">
            <ImageButton Source="back_icon.png"
                         Command="{Binding BackCommand}"
                         Grid.Column="0"
                         WidthRequest="30"
                         HeightRequest="30"
                         VerticalOptions="Center"/>
            <Label Text="Transaction History"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   Margin="10,0,0,0"
                   Grid.Column="1"/>
            <!-- Refresh button -->
            <ImageButton Source="refresh_icon.png"
                         Command="{Binding LoadCommand}"
                         Grid.Column="2"
                         WidthRequest="26"
                         HeightRequest="26"
                         VerticalOptions="Center"/>
        </Grid>

        <!-- Current filter label -->
        <Label Grid.Row="2" Grid.ColumnSpan="3" Text="{Binding FilterLabel}" HorizontalOptions="Center" FontAttributes="Italic" TextColor="#666" Margin="0,6,0,0" />

        <!-- Summary KPI strip -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*, *, *"
              BackgroundColor="White"
              Padding="10,8"
              Margin="0,0,0,4">

            <StackLayout Grid.Column="0" HorizontalOptions="Center">
                <Label Text="{Binding TotalTransactions}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Orders"
                       FontSize="11"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <StackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="{Binding TotalRevenueDisplay}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#2E7D32"
                       HorizontalOptions="Center"/>
                <Label Text="Revenue"
                       FontSize="11"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <StackLayout Grid.Column="2" HorizontalOptions="Center">
                <Label Text="{Binding TotalItemsSold}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Items Sold"
                       FontSize="11"
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </StackLayout>
        </Grid>

        <!-- Search Bar -->
        <SearchBar Placeholder="Search by ref#, product, payment…"
                   Grid.Row="2"
                   Margin="10,6,10,0"
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}"/>

        <!-- Date Filter Row -->
        <Grid Grid.Row="3"
              ColumnDefinitions="Auto, *, Auto"
              Padding="12,6,12,4">

            <CheckBox Grid.Column="0"
                      IsChecked="{Binding IsDateFilterActive}"
                      Color="#8B0000"
                      VerticalOptions="Center"/>

            <DatePicker Grid.Column="1"
                        Date="{Binding FilterDate}"
                        Format="MMM dd, yyyy"
                        IsEnabled="{Binding IsDateFilterActive}"
                        VerticalOptions="Center"
                        Margin="4,0"/>

            <Button Grid.Column="2"
                    Text="Clear"
                    Command="{Binding ClearDateFilterCommand}"
                    IsVisible="{Binding IsDateFilterActive}"
                    BackgroundColor="Transparent"
                    TextColor="#8B0000"
                    FontSize="12"
                    Padding="0"/>
        </Grid>

        <!-- Loading indicator -->
        <ActivityIndicator Grid.Row="4"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="#8B0000"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>

        <!-- Error message -->
        <Label Grid.Row="4"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               IsVisible="{Binding ErrorMessage, Converter={x:StaticResource StringNotEmptyConverter}}"
               Margin="16"/>

        <!-- Transaction List -->
        <CollectionView x:Name="transactionsCollectionView" Grid.Row="4"
                        ItemsSource="{Binding Transactions}"
                        SelectionMode="Single">

            <!-- Empty state -->
            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                    <Label Text="No transactions found."
                           TextColor="Gray"
                           HorizontalOptions="Center"/>
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="LightGray"
                           Margin="8,4"
                           Padding="12"
                           CornerRadius="10"
                           HasShadow="False">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">

                            <!-- Reference number -->
                            <Label Text="{Binding ReferenceNumber, StringFormat='# {0}'}"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   Grid.Row="0"
                                   Grid.Column="0"/>

                            <!-- Total (right-aligned) -->
                            <Label Text="{Binding TotalPayment}"
                                   TextColor="#2E7D32"
                                   FontAttributes="Bold"
                                   FontSize="15"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   HorizontalOptions="End"/>

                            <!-- Date | Time -->
                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   FontSize="12"
                                   TextColor="Gray">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Date, StringFormat='{0:MMM dd, yyyy}'}" />
                                        <Span Text="  ·  " />
                                        <Span Text="{Binding Time}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Payment method | Item count -->
                            <StackLayout Orientation="Horizontal"
                                         Spacing="12"
                                         Grid.Row="2"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="2">
                                <Label Text="{Binding PaymentMethod}"
                                       FontSize="12"
                                       TextColor="#555"/>
                                <Label Text="·" TextColor="Gray" FontSize="12"/>
                                <Label Text="{Binding ItemCount, StringFormat='{0} item(s)'}"
                                       FontSize="12"
                                       TextColor="#555"/>
                            </StackLayout>
                        </Grid>
                        <Frame.GestureRecognizers>
                            <!-- Use the page's BindingContext command so no vm xmlns is required -->
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ItemSelectedCommand}" CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
