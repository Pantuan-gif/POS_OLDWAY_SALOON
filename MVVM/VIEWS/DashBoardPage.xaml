<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             xmlns:models="clr-namespace:POS_OLDWAY_SALOON.MVVM.MODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.DashboardPage"
             BackgroundColor="#FFFFFF"
             Title="OLDWAY SALOON">

    <ContentPage.BindingContext>
        <vm:DashboardViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Divider -->
            <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" />

            <!-- ═══ NAV TABS ═══ -->
            <HorizontalStackLayout Padding="12,10"
                                   Spacing="8"
                                   BackgroundColor="{StaticResource TextWhite}">
                <Button Text="Products"
                        Style="{StaticResource NavButtonStyle}" />
                <Button Text="Inventory"
                        Style="{StaticResource NavButtonStyle}" />
                <Button Text="Reports"
                        Style="{StaticResource NavButtonStyle}" />
            </HorizontalStackLayout>

            <!-- ═══ MAIN CONTENT ═══ -->
            <VerticalStackLayout Padding="12,4,12,20" Spacing="0">

                <!-- Dashboard Title -->
                <Label Text="Dashboard"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="4,8,0,10" />

                <!-- ═══ STAT CARDS GRID ═══ -->
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="0"
                      RowSpacing="0">

                    <!-- Cashier Card -->
                    <Frame Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource StatCardStyle}">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <!-- Cashier Icon (Unicode fallback) -->
                                <Label Text="🧾"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <Label Text="Cashier"
                                       Style="{StaticResource CardTitleStyle}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding CashierCount}"
                                   Style="{StaticResource CardValueStyle}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Inventory Card -->
                    <Frame Grid.Row="0" Grid.Column="1"
                           Style="{StaticResource StatCardStyle}">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="📋"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <Label Text="Inventory"
                                       Style="{StaticResource CardTitleStyle}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding InventoryCount}"
                                   Style="{StaticResource CardValueStyle}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Today's Sale Card -->
                    <Frame Grid.Row="1" Grid.Column="0"
                           Style="{StaticResource StatCardStyle}">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="📊"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                                <Label Text="Today's Sale"
                                       Style="{StaticResource CardTitleStyle}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding TodaysSaleDisplay}"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource AccentGreen}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Transactions Card -->
                    <Frame Grid.Row="1" Grid.Column="1"
                           Style="{StaticResource StatCardStyle}">
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <Label Text="⇄"
                                       FontSize="16"
                                       TextColor="{StaticResource TextWhite}"
                                       VerticalOptions="Center" />
                                <Label Text="Transactions"
                                       Style="{StaticResource CardTitleStyle}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding TransactionsCount}"
                                   Style="{StaticResource CardValueStyle}" />
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- Recent Transactions Header -->
                <Label Text="Recent Transactions"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="4,16,0,4" />

                <!-- ═══ TRANSACTIONS LIST ═══ -->
                <Frame Padding="0"
                       CornerRadius="12"
                       HasShadow="False"
                       BorderColor="{StaticResource DividerColor}"
                       BackgroundColor="{StaticResource TextWhite}"
                       IsClippedToBounds="True">
                    <VerticalStackLayout Spacing="0">
                        <CollectionView ItemsSource="{Binding RecentTransactions}" SelectionMode="Single" SelectionChangedCommand="{Binding ItemSelectedCommand}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Transaction">
                                    <Grid Padding="12" ColumnDefinitions="56,*,Auto" ColumnSpacing="10">
                                        <Frame Grid.Column="0" Padding="4" CornerRadius="8" HasShadow="False" BorderColor="{StaticResource DividerColor}" BackgroundColor="{StaticResource TextWhite}" HeightRequest="52" WidthRequest="52" IsClippedToBounds="True" VerticalOptions="Center">
                                            <Image Source="{Binding ImageSource}" Aspect="AspectFit" HeightRequest="44" WidthRequest="44" />
                                        </Frame>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding ProductName}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource BrandDark}" />
                                            <Label FontSize="12" TextColor="{StaticResource TextGray}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding DateTime}" />
                                                        <Span Text=" | " />
                                                        <Span Text="{Binding Category}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label Text="{Binding AmountDisplay}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource AccentGreen}" HorizontalOptions="End" />
                                            <Label Text="{Binding QuantityDisplay}" FontSize="12" TextColor="{StaticResource BrandGold}" HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
