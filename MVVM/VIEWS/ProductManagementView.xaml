<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             xmlns:models="clr-namespace:POS_OLDWAY_SALOON.MVVM.MODELS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.ProductManagementView"
             x:DataType="vm:ProductManagementViewModel"
             Title="Product Management"
             BackgroundColor="#FFFFFF"
             Shell.NavBarIsVisible="False">

    <ContentPage.BindingContext>
        <vm:ProductManagementViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Spacing="0">

        <!-- Divider -->
        <BoxView HeightRequest="1" Color="#E0E0E0" />

        <!-- ── SEARCH + ADD PRODUCT ── -->
        <Grid Padding="12,10"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="8"
              BackgroundColor="#FFFFFF">

            <Frame Grid.Column="0"
                   Padding="10,0"
                   CornerRadius="8"
                   BorderColor="#CCCCCC"
                   HasShadow="False"
                   HeightRequest="42"
                   BackgroundColor="#FFFFFF">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                    <Label Grid.Column="0"
                           Text="🔍"
                           FontSize="14"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           Text="{Binding SearchText, Mode=TwoWay}"
                           Placeholder="Search"
                           PlaceholderColor="#AAAAAA"
                           FontSize="14"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center" />
                </Grid>
            </Frame>

            <Button Grid.Column="1"
                    Text="+ Add Product"
                    BackgroundColor="#4A2C0A"
                    TextColor="#FFFFFF"
                    FontSize="13"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="12,0"
                    HeightRequest="42"
                    Command="{Binding AddProductCommand}" />
        </Grid>

        <!-- Divider -->
        <BoxView HeightRequest="1" Color="#E0E0E0" />

        <!-- ── PRODUCT LIST ── -->
        <CollectionView ItemsSource="{Binding FilteredProducts}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <VerticalStackLayout Spacing="0">

                        <Grid Padding="14,12"
                              ColumnDefinitions="60,*,Auto"
                              ColumnSpacing="10">

                            <!-- Product Image -->
                            <Image Grid.Column="0"
                                   Source="{Binding PhotoPath}"
                                   Aspect="AspectFit"
                                   HeightRequest="56"
                                   WidthRequest="48"
                                   VerticalOptions="Center" />

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding ProductName}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#1A1005" />
                                <Label Text="{Binding CategoryName}"
                                       FontSize="12"
                                       TextColor="#888888" />
                                <Label Text="{Binding SizeDisplay}"
                                       FontSize="12"
                                       TextColor="#888888" />
                            </VerticalStackLayout>

                            <!-- Price + Stock + Actions -->
                            <Grid Grid.Column="2"
                                  RowDefinitions="Auto,Auto,Auto"
                                  RowSpacing="2"
                                  HorizontalOptions="End"
                                  VerticalOptions="Center">

                                <!-- Edit + Delete icons -->
                                <HorizontalStackLayout Grid.Row="0"
                                                       Spacing="8"
                                                       HorizontalOptions="End">
                                    <!-- Edit -->
                                    <Label Text="✏️"
                                           FontSize="18">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProductManagementViewModel}}, Path=EditProductCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <!-- Delete -->
                                    <Label Text="🗑️"
                                           FontSize="18">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProductManagementViewModel}}, Path=DeleteProductCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </HorizontalStackLayout>

                                <!-- Price -->
                                <Label Grid.Row="1"
                                       Text="{Binding PriceDisplay}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#2ECC71"
                                       HorizontalOptions="End" />

                                <!-- Stock -->
                                <Label Grid.Row="2"
                                       Text="{Binding StockDisplay}"
                                       FontSize="12"
                                       TextColor="#888888"
                                       HorizontalOptions="End" />
                            </Grid>
                        </Grid>

                        <!-- Row Divider -->
                        <BoxView HeightRequest="1"
                                 Color="#E0E0E0"
                                 Margin="14,0" />

                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>
