<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model ="clr-namespace:POS_OLDWAY_SALOON.MVVM.MODELS"
             xmlns:views ="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWS"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.FlyoutMenu"
             Title="FlyoutMenu">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Profile header -->
        <Grid Grid.Row="0" Padding="12" ColumnDefinitions="60,*">
            <Frame BackgroundColor="Transparent" Padding="0" HasShadow="False" CornerRadius="30" HeightRequest="56" WidthRequest="56">
                <Image x:Name="ProfileImage" Source="nullprofile.png" Aspect="AspectFill" HeightRequest="56" WidthRequest="56" />
            </Frame>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2" Padding="10,0,0,0">
                <Label x:Name="ProfileName" Text="Guest" FontAttributes="Bold" FontSize="16" TextColor="#1A1005" />
                <Label x:Name="ProfileRole" Text="" FontSize="12" TextColor="#888888" />
            </VerticalStackLayout>
        </Grid>

        <CollectionView x:Name="collectionView"
                        x:FieldModifier="public"
                        SelectionMode="Single"
                        Grid.Row="1">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:FlyoutMenuItem">
                    <Grid Padding="5,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding Icon}" />
                        <Label Grid.Column="1"
                               Margin="20,0"
                               Text="{Binding Title}"
                               FontSize="20"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Logout button pinned to bottom -->
        <Button Grid.Row="2"
                Text="Log out"
                BackgroundColor="#FFFFFF"
                TextColor="#5B341C"
                Margin="12"
                HorizontalOptions="Fill"
                Clicked="OnLogoutClicked" />
    </Grid>
                    
</ContentPage>