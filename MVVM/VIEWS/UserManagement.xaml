<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.UserManagement"
             xmlns:ViewModel="clr-namespace:POS_OLDWAY_SALOON.MVVM.VIEWMODELS"
             Title="UserManagement">
    
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- PROFILE CARD -->
        <Grid Grid.Row="0"
              Padding="15"
              ColumnDefinitions="80,0.2*,Auto"
              RowDefinitions="Auto,Auto,Auto"
              BackgroundColor="White">

            <Image Source="{Binding Image}"
                   HeightRequest="70"
                   WidthRequest="70"
                   Aspect="AspectFill"
                   Clip="EllipseGeometry Center=35,35 RadiusX=35 RadiusY=35"/>

            <VerticalStackLayout Grid.Column="1"
                                 Spacing="2">

                <Label 
                    x:Name="Fullname"
                    Text="{Binding FullName}"
                    FontSize="18"
                    FontAttributes="Bold"/>

                <Label x:Name="Role"
                       FontSize="14"
                       Text="{Binding Role}"
                       TextColor="Gray"/>

                <HorizontalStackLayout Spacing="5">
                    <BoxView WidthRequest="10"
                             HeightRequest="10"
                             BackgroundColor="Green"
                             CornerRadius="5"/>
                    <Label Text="Active"
                           FontSize="12"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>

            <Button Grid.Column="2"
                    Text="+ Add User"
                    Command="{Binding AddUserCommand}"
                    BackgroundColor="#5B341C"
                    TextColor="White"
                    CornerRadius="6"
                    HeightRequest="10"
                    Padding="15,8"/>

        </Grid>


        <!-- SEARCH + FILTER -->
        <Grid Grid.Row="1"
              Padding="15"
              ColumnDefinitions="*,Auto"
              ColumnSpacing="10">

            <SearchBar Placeholder="Search"
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding SearchCommand}"/>

            <Picker Grid.Column="1"
        Title="Filter"
        SelectedItem="{Binding SelectedFilter}">

                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Name</x:String>
                        <x:String>Role</x:String>
                        <x:String>Status</x:String>
                    </x:Array>
                </Picker.ItemsSource>

            </Picker>

        </Grid>


        <!-- USER LIST -->
        <CollectionView Grid.Row="2"
                        Margin="10"
                        ItemsSource="{Binding SearchResults}">

            <CollectionView.Header>
                <Grid Padding="10"
                      BackgroundColor="#E6E6E6"
                      ColumnDefinitions="2*,*,*">

                    <Label Text="User"
                           FontAttributes="Bold"/>

                    <Label Grid.Column="1"
                           Text="Role"
                           FontAttributes="Bold"/>

                    <Label Grid.Column="2"
                           Text="Actions"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"/>

                </Grid>
            </CollectionView.Header>


            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Grid Padding="10"
                          ColumnDefinitions="2*,*,auto"
                          RowDefinitions="Auto"
                          BackgroundColor="White"
                          Margin="0,0,0,2">

                        <!-- USER -->
                        <HorizontalStackLayout Grid.Column="0" Spacing="10">

                            <Image Source="{Binding ImageSource}"
                                   HeightRequest="40"
                                   WidthRequest="40"
                                   Aspect="AspectFill"
                                   Clip="EllipseGeometry Center=20,20 RadiusX=20 RadiusY=20"/>

                            <Label Text="{Binding FullName}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>


                        <!-- ROLE -->
                        <Label Grid.Column="1"
                               Text="{Binding Role}"
                               VerticalOptions="Center"/>


                        <!-- ACTIONS -->
                        <HorizontalStackLayout Grid.Column="2"
                                               HorizontalOptions="Center"
                                               Spacing="15">

                            <ImageButton Source="edit.png"
                                         HeightRequest="24"
                                         WidthRequest="24"
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditUserCommand}"
                                         CommandParameter="{Binding .}" />

                            <ImageButton Source="delete.png"
                                         HeightRequest="24"
                                         WidthRequest="24"
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteUserCommand}"
                                         CommandParameter="{Binding .}" />

                        </HorizontalStackLayout>

                    </Grid>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>