<?xml version="1.0" encoding="utf-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Button" x:Key="SignUp">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary},Dark={StaticResource PrimaryDark}}"/>
        <Setter Property="WidthRequest" Value="100"/>
    </Style>

    <Style TargetType="Border" x:Key="EntryBorder">
        <Setter Property="StrokeShape" Value="RoundRectangle 5"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="Stroke" Value="Black"/>
        <Setter Property="HeightRequest" Value="40"/>
    </Style>
    <!-- Colors -->
    <Color x:Key="BrandDark">#1A1005</Color>
    <Color x:Key="BrandBrown">#4A2C0A</Color>
    <Color x:Key="BrandGold">#8B5E1A</Color>
    <Color x:Key="CardBackground">#1C1008</Color>
    <Color x:Key="AccentGreen">#2ECC71</Color>
    <Color x:Key="TextWhite">#FFFFFF</Color>
    <Color x:Key="TextGray">#888888</Color>
    <Color x:Key="DividerColor">#E0E0E0</Color>

    <!-- Card Style -->
    <Style x:Key="StatCardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16,14" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="Margin" Value="4" />
    </Style>

    <!-- Nav Button Style -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandGold}" />
        <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="HeightRequest" Value="40" />
    </Style>

    <!-- Section Header Style -->
    <Style x:Key="SectionHeaderStyle" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource BrandDark}" />
        <Setter Property="Margin" Value="0,12,0,8" />
    </Style>

    <!-- Card Title Style -->
    <Style x:Key="CardTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <!-- Card Value Style -->
    <Style x:Key="CardValueStyle" TargetType="Label">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>
</ResourceDictionary>