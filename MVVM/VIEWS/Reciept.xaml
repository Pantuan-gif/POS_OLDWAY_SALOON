<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="POS_OLDWAY_SALOON.MVVM.VIEWS.Reciept"
             Title="Reciept"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                <Label Text="☰"
                       FontSize="24"
                       VerticalOptions="Center"/>

                <Label Text="E-Receipt"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Grid.Column="1"/>

                <BoxView WidthRequest="24" Grid.Column="2"/>
            </Grid>

            <!-- Receipt Card -->
            <Frame CornerRadius="20"
                   BackgroundColor="#5C2E0C"
                   Padding="20"
                   HasShadow="True">

                <VerticalStackLayout Spacing="15">

                    <!-- Check Icon -->
                    <Frame BackgroundColor="Green"
                           CornerRadius="40"
                           WidthRequest="60"
                           HeightRequest="60"
                           HorizontalOptions="Center"
                           Padding="0">
                        <Label Text="✔"
                               FontSize="28"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Frame>

                    <!-- Store Info -->
                    <Label Text="OLDWAY SALOON"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <Label Text="Liquor Store"
                           FontSize="12"
                           TextColor="#DDDDDD"
                           HorizontalOptions="Center"/>

                    <Label Text="46551 140th Street East, Lancaster, California"
                           FontSize="12"
                           TextColor="#DDDDDD"
                           HorizontalTextAlignment="Center"/>

                    <!-- Details -->
                    <Grid ColumnDefinitions="*,Auto" RowSpacing="8">

                        <Label Text="Reference Number" TextColor="White"/>
                        <Label Text="{Binding ReferenceNumber}" Grid.Column="1" TextColor="White"/>

                        <Label Text="Date" Grid.Row="1" TextColor="White"/>
                        <Label Text="{Binding Date}" Grid.Row="1" Grid.Column="1" TextColor="White"/>

                        <Label Text="Time" Grid.Row="2" TextColor="White"/>
                        <Label Text="{Binding Time}" Grid.Row="2" Grid.Column="1" TextColor="White"/>

                        <Label Text="Payment Method" Grid.Row="3" TextColor="White"/>
                        <Label Text="{Binding PaymentMethod}" Grid.Row="3" Grid.Column="1" TextColor="White"/>

                        <Label Text="No. Items" Grid.Row="4" TextColor="White"/>
                        <Label Text="{Binding ItemCount}" Grid.Row="4" Grid.Column="1" TextColor="White"/>

                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" BackgroundColor="#AAAAAA"/>

                    <!-- Total -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Total Payment"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Label Text="{Binding TotalPayment}"
                               Grid.Column="1"
                               FontAttributes="Bold"
                               TextColor="#00FF7F"/>
                    </Grid>

                    <!-- Note -->
                    <Label Text="Note: Please show this receipt and pay to the cashier"
                           FontSize="11"
                           TextColor="#DDDDDD"/>

                    <Label Text="Thank you!"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="White"/>

                </VerticalStackLayout>
            </Frame>

            <!-- Back Button -->
            <Button Text="← Back To PRODUCTS"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="#5C2E0C"
                    FontAttributes="Bold"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>